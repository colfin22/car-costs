# Copy to .env (and point your service manager at it, e.g. a systemd
# EnvironmentFile) — .env itself must never be committed.

# Enables the login gate for internet-facing use. Leave unset on a purely
# internal deployment and the app runs open. Rotating the value signs out
# every session.
CARCOSTS_PASSWORD=change-me

# Optional: where the SQLite database lives (photos are stored beside it).
# Defaults to ./data/carcosts.db
#CARCOSTS_DB=/opt/carcosts/data/carcosts.db
